# ============================================================
# Research Paper Screening Agent — Backend Environment
# Copy this file to .env and fill in the values
# ============================================================

# Supabase
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_KEY=your-supabase-service-role-key  # NOT the anon key

# Groq LLM
GROQ_API_KEY=your-groq-api-key

# JWT Auth — generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=your-long-random-secret-key-here
JWT_EXPIRY_DAYS=7

# Agent Config
DAILY_AGENT_SECRET=your-random-agent-trigger-secret
MAX_PAPERS_PER_RUN=200
ARXIV_QUERY_TERMS=AI,machine learning,deep learning,NLP,transformer,language model,cybersecurity,security,computer vision,robotics,software engineering
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.LG,cs.CR,cs.CV,cs.RO,cs.SE,cs.HC,stat.ML

# CORS (comma-separated list in JSON array format)
ALLOWED_ORIGINS=["http://localhost:5173","https://your-frontend.vercel.app"]
