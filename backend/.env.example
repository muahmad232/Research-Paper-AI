# ============================================================
# Research Paper Screening Agent — Backend Environment
# Copy this file to .env and fill in the values
# ============================================================

# Supabase
SUPABASE_URL=urlll
SUPABASE_KEY=key

# Groq LLM
GROQ_API_KEY=groq-qpi-key

# Agent Config
DAILY_AGENT_SECRET=random-key
MAX_PAPERS_PER_RUN=200
ARXIV_QUERY_TERMS=LLM,RAG,multi-agent,transformer
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.LG

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
